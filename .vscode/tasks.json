{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Make: quality",
			"type": "shell",
			"command": "make",
			"args": [
				"quality"
			],
			"group": "build",
			"problemMatcher": [
				{
					"owner": "python",
					"source": "vulture",
					"severity": "warning",
					"fileLocation": [
						"relative",
						"${workspaceFolder}/src"
					],
					"pattern": {
						"regexp": "^(.+?):(\\d+): (.*)$",
						"file": 1,
						"line": 2,
						"message": 3
					}
				}
			],
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "Make: vulture",
			"type": "shell",
			"command": "make",
			"args": [
				"vulture"
			],
			"group": "build",
			"problemMatcher": [
				{
					"owner": "python",
					"source": "vulture",
					"severity": "warning",
					"fileLocation": [
						"relative",
						"${workspaceFolder}/src"
					],
					"pattern": {
						"regexp": "^(.+?):(\\d+): (.*)$",
						"file": 1,
						"line": 2,
						"message": 3
					}
				}
			],
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "Activate conda: mlx-vlm",
			"type": "shell",
			"command": "zsh",
			"args": [
				"-lc",
				"conda activate mlx-vlm && echo 'conda mlx-vlm activated'"
			],
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "Make: test",
			"type": "shell",
			"command": "make",
			"args": [
				"test"
			],
			"group": "test",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "Run: check_models (help)",
			"type": "shell",
			"command": "conda",
			"args": [
				"run",
				"-n",
				"mlx-vlm",
				"python",
				"-m",
				"check_models",
				"--help"
			],
			"options": {
				"cwd": "${workspaceFolder}/src"
			},
			"group": "none",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "VLM: Quality checks (ruff format + fix + mypy)",
			"type": "shell",
			"command": "bash",
			"args": [
				"src/tools/run_quality_checks.sh"
			],
			"options": {
				"env": {
					"ZSH_DISABLE_COMPFIX": "true"
				}
			},
			"isBackground": false,
			"problemMatcher": [
				{
					"owner": "python",
					"source": "vulture",
					"severity": "warning",
					"fileLocation": [
						"relative",
						"${workspaceFolder}/src"
					],
					"pattern": {
						"regexp": "^(.+?):(\\d+): (.*)$",
						"file": 1,
						"line": 2,
						"message": 3
					}
				}
			],
			"group": "build"
		},
		{
			"label": "VLM: Run Check Models",
			"type": "shell",
			"command": "conda",
			"args": [
				"run",
				"-n",
				"mlx-vlm",
				"python",
				"src/check_models.py"
			],
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			}
		}
	]
}