{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Make: quality",
			"type": "shell",
			"command": "make",
			"args": [
				"quality"
			],
			"group": "build",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "Activate conda: mlx-vlm",
			"type": "shell",
			"command": "zsh",
			"args": [
				"-lc",
				"conda activate mlx-vlm && echo 'conda mlx-vlm activated'"
			],
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "Make: test",
			"type": "shell",
			"command": "make",
			"args": [
				"test"
			],
			"group": "test",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "Run: check_models (help)",
			"type": "shell",
			"command": "python",
			"args": [
				"-m",
				"check_models",
				"--help"
			],
			"options": {
				"cwd": "${workspaceFolder}/src"
			},
			"group": "none",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "VLM: Quality checks (ruff format + fix + mypy)",
			"type": "shell",
			"command": "bash",
			"args": [
				"src/tools/run_quality_checks.sh"
			],
			"options": {
				"env": {
					"ZSH_DISABLE_COMPFIX": "true"
				}
			},
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "VLM: Run Check Models",
			"type": "shell",
			"command": "python",
			"args": [
				"src/check_models.py"
			],
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			}
		},
		{
			"label": "Rebuild model gallery",
			"type": "shell",
			"command": "conda",
			"args": [
				"run",
				"-n",
				"mlx-vlm",
				"python",
				"/tmp/rebuild_model_gallery.py"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Lint model gallery",
			"type": "shell",
			"command": "npx",
			"args": [
				"--prefix",
				"src",
				"markdownlint",
				"src/output/model_gallery.md"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Lint model gallery",
			"type": "shell",
			"command": "npx",
			"args": [
				"--prefix",
				"src",
				"markdownlint-cli2",
				"src/output/model_gallery.md"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Lint model gallery cli2",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"cd src && npx markdownlint-cli2 output/model_gallery.md"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Rebuild model gallery 2",
			"type": "shell",
			"command": "conda",
			"args": [
				"run",
				"-n",
				"mlx-vlm",
				"python",
				"/tmp/rebuild_model_gallery.py"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Lint model gallery cli2 v2",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"cd src && npx markdownlint-cli2 output/model_gallery.md"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Rebuild model gallery 3",
			"type": "shell",
			"command": "conda",
			"args": [
				"run",
				"-n",
				"mlx-vlm",
				"python",
				"/tmp/rebuild_model_gallery.py"
			],
			"isBackground": false,
			"group": "build"
