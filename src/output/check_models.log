def filter_and_sort_people(people):
    # Filter people who are over 18 and taller than 170 cm
    filtered_people = [person for person in people if person['age'] > 18 and person['height'] > 170]
    
    # Sort the filtered list by age in descending order and then by height in ascending order
    sorted_people = sorted(filtered_people, key=lambda x: (-x['age'], x['height']))
    
