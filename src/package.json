{
  "name": "mlx-vlm-check-dev-tools",
  "version": "0.1.0",
  "description": "Development tooling for MLX VLM Check (Markdown linting)",
  "private": true,
  "devDependencies": {
    "markdownlint-cli2": "^0.22.1"
  },
  "overrides": {
    "smol-toml": "1.6.1"
  },
  "scripts": {
    "lint:md": "markdownlint-cli2 --config ../.markdownlint.jsonc '**/*.md' '#node_modules'"
  }
}